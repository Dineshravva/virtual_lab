# --- Required ---------------------------------------------------------------
PORT=5000
MONGO_URI=mongodb://localhost:27017/virtual-lab
CLIENT_URL=http://localhost:3000

# --- Optional: AI Lab Assistant ---------------------------------------------
# Required only if you want the AI Lab Assistant panel to answer questions.
# Without OPENAI_API_KEY the panel returns a friendly "not configured" message
# and the rest of the app works normally.
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini
